{
  "source_id": "SRC001",
  "source_name": "Endometriosis Australia",
  "source_type": "news_blog",
  "base_url": "https://endometriosisaustralia.org",
  "start_url": "https://endometriosisaustralia.org/blog/",
  "country": "Australia",
  "language": "en",
  "listing_mode": "blog_pagination",
  "listing_page_template": "https://endometriosisaustralia.org/blog/page/{page}/?et_blog=",
  "start_page": 1,
  "max_pages": 200,
  "request_timeout": 30,
  "sleep_seconds": 1.5,
  "selectors": {
    "article_cards": "h2 a, article h2 a, .et_pb_post h2 a, .entry-title a",
    "title": "h1",
    "body": "article, main article, .et_pb_post, .post, .entry-content, .et_post_meta_wrapper",
    "meta": ".post-meta, .et_pb_title_meta_container, article .post-meta",
    "author_links": ".post-meta a[rel*='author'], .author a, a[rel*='author']",
    "category_links": ".post-meta a[rel*='category tag'], .post-meta a[rel*='category'], .cat-links a"
  },
  "remove_selectors": [
    "script",
    "style",
    "nav",
    "header nav",
    "footer",
    "form",
    ".sharedaddy",
    ".sd-content",
    ".jp-relatedposts",
    ".et_social_inline",
    ".et_social_icons_container",
    ".et_pb_sidebar",
    ".sidebar",
    ".widget",
    ".related-posts",
    ".comment-respond",
    ".comments-area",
    ".comments",
    ".search-form",
    ".et_pb_search",
    ".mobile_menu_bar",
    ".pagination",
    ".pager",
    ".et_pb_posts_nav",
    ".author-box"
  ],
  "output_file": "outputs/SRC001/SRC001_post_and_comment_final.jsonl",
  "error_file": "outputs/SRC001/SRC001_errors_final.jsonl"
}
