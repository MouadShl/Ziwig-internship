    ".sharedaddy",
    ".jp-relatedposts",
    ".comments-area",
    "#comments",
    ".comment-respond",
    ".commentlist",
    ".et_social_inline",
    ".et_pb_post_nav",
    ".related-posts",
    ".post-share",
    ".sidebar",
    ".widget",
    ".breadcrumbs",
    ".et_pb_title_featured_container",
    ".wp-block-buttons",
    ".wp-block-button",
    ".sharedaddy",
    ".sd-sharing-enabled",
    ".yarpp-related",
    ".et_pb_section_video_bg",
    ".wp-block-embed"
  ],
  "sleep_seconds": 1.2
}
