      ".et_pb_posts h2 a",
      ".post-content h2 a",
      "main h2 a"
    ],
    "title": [
      "h1.entry-title",
      ".et_pb_title h1",
      "article h1",
      "main h1",
      "h1"
    ],
    "meta": [
      ".post-meta",
      ".entry-meta",
      ".et_pb_title_meta_container",
      "article .post-meta",
      "main .post-meta"
    ],
    "body": [
      ".entry-content",
      "article .entry-content",
      ".et_pb_post .entry-content",
      ".post-content",
      ".et-l--post .entry-content",
      "article",
      "main article",
      "main"
    ],
    "tags": [
      "a[rel='tag']",
      ".tagcloud a",
      ".post-tags a"
    ]
  },
  "remove_selectors": [
    "script",
    "style",
    "noscript",
    "svg",
    "form",
    "iframe",
    "nav",
    "header nav",
